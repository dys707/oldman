# LLM API配置
LLM_PROVIDER=openai          # 可选: openai, zhipu
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-3.5-turbo
LLM_BASE_URL=https://api.openai.com/v1

# 向量数据库路径
VECTOR_DB_PATH=./vector_db/chroma_store

# 检索参数
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.4

# 应用设置
APP_TITLE=老年人心理健康助手
APP_DESCRIPTION=基于专业心理量表的初步评估工具